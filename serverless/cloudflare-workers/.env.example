# 阿里百炼 API Key（必填）
# 获取地址: https://bailian.console.aliyun.com/
QWEN_API_KEY=sk-your-api-key-here

# 每 IP 每分钟最大请求数（可选，默认 5；滑动窗口算法）
RATE_LIMIT=5

# Web Push VAPID 私钥（可选，用于后台推送）
# 生成工具: https://www.vapidkeys.com/
VAPID_PRIVATE_KEY=your-vapid-private-key

# ModelScope MCP 服务（可选）
# 获取地址: https://www.modelscope.cn/my/myaccesstoken
# 配置后可自动获取 HowToCook-MCP 和 kb-mcp-server 的 operational URL
MODELSCOPE_API_TOKEN=your-modelscope-token

# 如需直接指定 MCP operational URL，可配置以下变量（优先于自动获取）
# HOWTOCOOK_MCP_URL=https://mcp.api-inference.modelscope.net/xxx/streamable_http
# KNOWLEDGE_MCP_URL=https://mcp.api-inference.modelscope.net/xxx/streamable_http
# STRAVA_MCP_URL=https://mcp.api-inference.modelscope.net/xxx/mcp
