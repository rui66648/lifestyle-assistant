{
  "name": "lifestyle-assistant",
  "version": "1.4.0",
  "description": "",
  "main": "sw.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "sync:android": "npx cap sync android",
    "build:apk": "npm run build && npm run sync:android && cd android && gradlew.bat assembleDebug",
    "build:release": "npm run build:apk && node scripts/build-android.mjs --release",
    "build:aab": "npm run build:apk && node scripts/build-android.mjs --aab",
    "deploy": "npm run build && git push origin master",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rui66648/lifestyle-assistant.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rui66648/lifestyle-assistant/issues"
  },
  "homepage": "https://github.com/rui66648/lifestyle-assistant#readme",
  "dependencies": {
    "@capacitor/browser": "^8.0.4",
    "acorn": "^8.17.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@vitest/coverage-v8": "^2.1.8",
    "cssnano": "^8.0.2",
    "jsdom": "^25.0.1",
    "terser": "^5.49.0",
    "vitest": "^2.1.8"
  }
}
