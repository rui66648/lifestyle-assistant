# ============================================================
# Android 签名配置（示例文件）
# ------------------------------------------------------------
# 使用前复制此文件为 keystore.properties（同目录），填入真实值。
# keystore.properties 已被 .gitignore 忽略，不会进入版本库。
#
# 生成新 keystore（首次发布时执行一次）：
#   keytool -genkeypair -v ^
#     -keystore android/app/release.jks ^
#     -alias release ^
#     -keyalg RSA -keysize 2048 -validity 10000 ^
#     -storepass <你的密码> -keypass <你的密码>
#
# ⚠️ release.jks 是应用身份的唯一凭证，丢失后无法找回，
#    请备份到安全位置（如加密 U 盘 / 密码管理器附件）。
# ============================================================

storeFile=release.jks
storePassword=你的keystore密码
keyAlias=release
keyPassword=你的key密码
